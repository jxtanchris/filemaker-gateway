# FileMaker Gateway 环境变量配置
# 复制此文件为 .env 并填入实际值

# Provider API Key
FILEMAKER_GATEWAY_PROVIDER_API_KEY=sk-your-api-key-here

# Provider API Base (可选，用于自定义 endpoint)
# FILEMAKER_GATEWAY_PROVIDER_API_BASE=https://api.deepseek.com

# Gateway API Key (FileMaker 调用时需要)
FILEMAKER_GATEWAY_API_KEY=filemaker-secret-key-change-me
